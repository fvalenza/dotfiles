{
  "color_scheme": "Packages/Predawn/predawn-markdown.tmTheme",
  "draw_centered": false, // Centers the column in the window
  "draw_indent_guides": true,
  "trim_trailing_white_space_on_save": false,
  "font_size": 9,
  "word_wrap": true,
  "wrap_width": 120,  // Sets the # of characters per line
  "enable_table_editor": true,
  "table_editor_syntax": "Auto",
  "tab_size": 2,
  "rulers":
  [
    80,
    120
  ],
  "extensions":
  [
    "mdown",
    "txt",
    "md"
  ]
}
